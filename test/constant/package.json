{
	"name": "@lisachandra/test-constant",
	"version": "0.0.0",
	"description": "Runtime test place for validating constant builder, persistence, and live-edit behavior.",
	"keywords": ["roblox", "rbxts", "test", "constants", "jest-roblox"],
	"private": true,
	"type": "module",
	"scripts": {
		"build": "shx rm -rf out && rbxtsc --type 'game' --includePath node_modules/@lisachandra/types/out/include --noInclude --verbose --allowCommentDirectives",
		"dev": "rbxtsc --type 'game' --includePath node_modules/@lisachandra/types/out/include --noInclude --watch --allowCommentDirectives",
		"serve:rbx-tree": "io-serve",
		"serve:sourcemap": "rojo sourcemap --watch default.project.json --output sourcemap.json",
		"serve:rojo": "rojo serve default.project.json",
		"test": "pnpm exec jest-roblox ./jest.config.ts"
	},
	"devDependencies": {
		"@isentinel/jest-roblox": "catalog:",
		"roblox-ts": "catalog:",
		"@isentinel/tsconfig": "catalog:",
		"@rbxts/compiler-types": "catalog:",
		"@rbxts/types": "catalog:",
		"io-serve": "catalog:",
		"shx": "catalog:",
		"typescript": "catalog:"
	},
	"dependencies": {
		"@rbxts/services": "catalog:",
		"@rbxts/jest": "catalog:",
		"@rbxts/jest-globals": "catalog:",
		"@lisachandra/types": "catalog:",
		"@lisachandra/core": "catalog:",
		"@lisachandra/constant": "workspace:*"
	}
}
