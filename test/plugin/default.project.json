{
	"name": "test",
	"globIgnorePaths": ["**/package.json", "**/tsconfig.json"],
	"emitLegacyScripts": false,
	"tree": {
		"$className": "DataModel",
		"ReplicatedStorage": {
			"$className": "ReplicatedStorage",
			"plugin:tests": {
				"$path": "out"
			},
			"rbxts_include": {
				"$className": "Folder",
				"node_modules": {
					"$className": "Folder",
					"@lisachandra": {
						"$path": "node_modules/@lisachandra",
						"plugin": {
							"$path": "../../packages/plugin/out"
						}
					},
					"@rbxts": {
						"$path": "node_modules/@rbxts"
					},
					"@rbxts-js": {
						"$path": "node_modules/@rbxts-js"
					}
				}
			}
		},
		"ServerScriptService": {
			"$className": "ServerScriptService",
			"$properties": {
				"LoadStringEnabled": true
			}
		},
		"TestService": {
			"$className": "TestService",
			"$properties": {
				"AutoRuns": false,
				"ExecuteWithStudioRun": false
			}
		}
	}
}
