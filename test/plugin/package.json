{
	"name": "@lisachandra/test-plugin",
	"version": "0.0.0",
	"description": "Plugin test place for validating constant Studio bridge and io-serve integration.",
	"keywords": ["roblox", "rbxts", "test", "plugin", "io-serve"],
	"private": true,
	"type": "module",
	"scripts": {
		"build": "shx rm -rf out && rbxtsc --type 'game' --includePath out/include --noInclude --verbose --allowCommentDirectives",
		"dev:source": "rbxtsc --type 'game' --includePath out/include --noInclude --watch --allowCommentDirectives",
		"dev": "pnpm run \"/^dev:.*/\"",
		"serve": "pnpm run \"/^serve:.*/\"",
		"serve:rbx-tree": "io-serve",
		"serve:sourcemap": "rojo sourcemap --watch default.project.json --output sourcemap.json",
		"serve:rojo": "rojo serve default.project.json",
		"test": "pnpm exec jest-roblox --config jest.config.ts"
	},
	"devDependencies": {
		"@isentinel/jest-roblox": "catalog:",
		"@lisachandra/types": "catalog:",
		"@lisachandra/constant": "workspace:*",
		"@lisachandra/plugin": "workspace:*",
		"@rbxts/services": "catalog:",
		"roblox-ts": "catalog:",
		"@isentinel/tsconfig": "catalog:",
		"@rbxts/compiler-types": "catalog:",
		"@rbxts/jest": "catalog:",
		"@rbxts/jest-globals": "catalog:",
		"@rbxts/types": "catalog:",
		"io-serve": "catalog:",
		"shx": "catalog:",
		"typescript": "catalog:"
	}
}
