#!/bin/bash
INPUT=$(cat)
COMMAND=$(echo "$INPUT" | jq -r '.tool_input.command')

MATCH=$(echo "$COMMAND" | grep -oE '(^|\s|&&|\|\||;)(npm|yarn|bun|npx)(\s|$)' | head -1 | tr -d ' ;|&')
if [ -n "$MATCH" ]; then
  echo "Blocked: use pnpm instead of $MATCH" >&2
  exit 2
fi

# Block pnpm install/i/add in favor of pncat
if echo "$COMMAND" | grep -qE '(^|\s|&&|\|\||;)pnpm\s+(install|i|add)(\s|$)'; then
  echo "Blocked: use pncat instead of pnpm install/add" >&2
  exit 2
fi

exit 0