{
	"name": "constant",
	"version": "0.0.0",
	"description": "Monorepo for the constant Roblox-TS package, Studio plugin bridge, and test places.",
	"keywords": ["roblox", "rbxts", "constants", "configuration", "debugging"],
	"private": true,
	"type": "module",
	"scripts": {
		"build": "pnpm -r run build",
		"dev": "pnpm -r run dev",
		"test": "pnpm build && COLUMNS=${COLUMNS:-$(tput cols 2>/dev/null || echo 80)} FORCE_COLOR=1 pnpm -r --parallel --stream test",
		"serve": "pnpm -r run serve",
		"build:packages": "pnpm --filter \"./packages/**\" build",
		"build:test": "pnpm --filter \"./test/**\" build",
		"dev:packages": "pnpm --filter \"./packages/**\" dev",
		"dev:test": "pnpm --filter \"./test/**\" dev",
		"release": "pnpm -r publish --access=public && changeset tag",
		"version": "changeset version"
	},
	"devDependencies": {
		"@lisachandra/types": "catalog:",
		"@changesets/changelog-github": "catalog:",
		"@changesets/cli": "catalog:",
		"@isentinel/jest-roblox": "catalog:",
		"roblox-ts": "catalog:",
		"@isentinel/tsconfig": "catalog:",
		"@rbxts/compiler-types": "catalog:",
		"@rbxts/types": "catalog:",
		"husky": "catalog:",
		"io-serve": "catalog:",
		"shx": "catalog:",
		"typescript": "catalog:"
	},
	"packageManager": "pnpm@10.33.0"
}
