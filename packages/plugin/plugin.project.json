{
	"name": "plugin",
	"tree": {
		"$className": "Folder",
		"rbxts_include": {
			"$className": "Folder",
			"node_modules": {
				"$className": "Folder",
				"@rbxts": {
					"$path": "node_modules/@rbxts"
				},
				"@lisachandra": {
					"$path": "node_modules/@lisachandra",
					"plugin": {
						"$path": "out"
					}
				}
			}
		}
	}
}
