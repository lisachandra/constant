{
	"name": "@lisachandra/plugin",
	"version": "0.1.0",
	"description": "Studio plugin bridge for syncing live constant edits to JSON files through io-serve.",
	"keywords": ["roblox", "rbxts", "plugin", "constants", "io-serve"],
	"homepage": "https://github.com/lisachandra/constant",
	"bugs": {
		"url": "https://github.com/lisachandra/constant/issues"
	},
	"repository": {
		"url": "https://github.com/lisachandra/constant",
		"type": "git"
	},
	"license": "MIT",
	"author": "lisachandra <lisachandra@proton.me>",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"source": "./src/index.ts",
			"import": "./out/init.luau",
			"types": "./out/index.d.ts"
		}
	},
	"main": "out/init.luau",
	"types": "out/index.d.ts",
	"files": ["out", "default.project.json", "!**/*.tsbuildinfo"],
	"scripts": {
		"build:plugin": "pnpm run build && rojo build plugin.project.json --output ../../constant.rbxm",
		"build": "rbxtsc --verbose --allowCommentDirectives",
		"dev": "rbxtsc --watch --allowCommentDirectives",
		"clean": "shx rm -rf out"
	},
	"devDependencies": {
		"roblox-ts": "catalog:",
		"@lisachandra/types": "catalog:",
		"@isentinel/tsconfig": "catalog:",
		"@rbxts/compiler-types": "catalog:",
		"@rbxts/types": "catalog:",
		"@rbxts/services": "catalog:",
		"shx": "catalog:"
	},
	"peerDependencies": {
		"@rbxts/services": "*"
	},
	"publishConfig": {
		"access": "public"
	}
}
