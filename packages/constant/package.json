{
	"name": "@lisachandra/constant",
	"version": "0.1.0",
	"description": "Strongly-typed, chainable runtime constants with JSON persistence and Studio Iris editing for roblox-ts.",
	"keywords": ["roblox", "rbxts", "constants", "configuration", "iris"],
	"homepage": "https://github.com/lisachandra/constant",
	"bugs": {
		"url": "https://github.com/lisachandra/constant/issues"
	},
	"repository": {
		"url": "https://github.com/lisachandra/constant",
		"type": "git"
	},
	"license": "MIT",
	"author": "lisachandra <lisachandra@proton.me>",
	"private": false,
	"type": "module",
	"exports": {
		".": {
			"source": "./src/index.ts",
			"import": "./out/init.luau",
			"types": "./out/index.d.ts"
		}
	},
	"main": "out/init.luau",
	"types": "out/index.d.ts",
	"files": ["out", "default.project.json", "!**/*.tsbuildinfo"],
	"scripts": {
		"prepare": "pnpm run build",
		"build": "rbxtsc --verbose --allowCommentDirectives",
		"dev": "rbxtsc --watch --allowCommentDirectives",
		"clean": "shx rm -rf out"
	},
	"devDependencies": {
		"roblox-ts": "catalog:",
		"@isentinel/tsconfig": "catalog:",
		"@rbxts/compiler-types": "catalog:",
		"@lisachandra/types": "catalog:",
		"@rbxts/types": "catalog:",
		"@rbxts/services": "catalog:",
		"@rbxts/luau-polyfill": "catalog:",
		"@rbxts/iris": "catalog:",
		"shx": "catalog:"
	},
	"peerDependencies": {
		"@rbxts/services": "*",
		"@rbxts/luau-polyfill": "*",
		"@rbxts/iris": "*"
	},
	"publishConfig": {
		"access": "public"
	}
}
